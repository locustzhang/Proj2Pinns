# ==============================================================================
def eval_residual_oos_proj(model, residual_fn, n=N_RESID_TEST, batch_size=500):
    model.eval()
    chunks = []
    done = 0
    with torch.enable_grad():
        while done < n:
            m = min(batch_size, n - done)
            x = torch.rand(m, 1, device=DEVICE) * (X_MAX - X_MIN) + X_MIN
            t = torch.rand(m, 1, device=DEVICE) * T_FINAL
            xt = torch.cat([x, t], dim=1).requires_grad_(True)
            u = model.forward_proj(xt) if isinstance(model, TwoStageProjPINN) else model(xt)
            r = residual_fn(u, xt)
            r2 = (r**2).mean(dim=1).detach()
            chunks.append(r2)
            done += m
            if DEVICE.type == "cuda":
                torch.cuda.empty_cache()
    r2_all = torch.cat(chunks, dim=0)
    return {"mean": float(r2_all.mean().item()),
            "max": float(r2_all.max().item()),
            "p95": float(torch.quantile(r2_all, 0.95).item())}


# ==============================================================================
# 新增：投影参数统计（α/s的最大/平均值，支撑"微扰"结论）
# ==============================================================================
def get_projection_stats(model, ts):
    if not isinstance(model, TwoStageProjPINN) or not model._proj_enabled:
        return None
    params = []
    for t in ts:
        t_val = float(t)
        if model.out_dim == 1:
            if model._pde_name == "KdV":
                params.append(model._compute_kdv_alpha(t_val))
            elif model._pde_name == "KS":
                params.append(model._compute_ks_alpha(t_val))
            else:
                params.append(model._compute_kdv_alpha(t_val))
        else:
            params.append(model._compute_nls_scale(t_val))
    params_np = np.array(params)
    if model.out_dim == 1:
        return {
            "mean_abs_alpha": float(np.mean(np.abs(params_np))),
            "max_abs_alpha": float(np.max(np.abs(params_np))),
            "std_alpha": float(np.std(params_np))
        }
    else:
        return {
            "mean_abs_s_minus_1": float(np.mean(np.abs(params_np - 1.0))),
            "max_abs_s_minus_1": float(np.max(np.abs(params_np - 1.0))),
            "std_s": float(np.std(params_np))
        }


def eval_vs_reference_raw(model, x_ref, t_ref, u_ref, out_dim):
    model.eval()

    x_pt = torch.tensor(x_ref, device=DEVICE, dtype=torch.float32)
    t_pt = torch.tensor(t_ref, device=DEVICE, dtype=torch.float32)

    nx = x_pt.shape[0]
    nt = t_pt.shape[0]

    X = x_pt.view(1, nx).repeat(nt, 1)
    T = t_pt.view(nt, 1).repeat(1, nx)

    xt = torch.stack([X, T], dim=2).reshape(nt * nx, 2)

    with torch.no_grad():
        if isinstance(model, TwoStageProjPINN):
            u_pred = model.forward_raw(xt).reshape(nt, nx, out_dim).cpu().numpy()
        else:
            u_pred = model(xt).reshape(nt, nx, out_dim).cpu().numpy()

    errs_l2, errs_linf = [], []
    for i in range(nt):
        u_true = u_ref[i]
        if out_dim == 1:
            e = u_pred[i, :, 0] - u_true[:, 0]
            errs_l2.append(float(np.sqrt(np.mean(e**2))))
            errs_linf.append(float(np.max(np.abs(e))))
        else:
            er = u_pred[i, :, 0] - u_true[:, 0]
            ei = u_pred[i, :, 1] - u_true[:, 1]
            en = np.sqrt(er**2 + ei**2)
            errs_l2.append(float(np.sqrt(np.mean(en**2))))
            errs_linf.append(float(np.max(en)))

    return {"t": t_ref.tolist(), "l2": errs_l2, "linf": errs_linf,
            "mean_l2": float(np.mean(errs_l2)), "max_linf": float(np.max(errs_linf))}


def eval_vs_reference_proj(model, x_ref, t_ref, u_ref, out_dim):
    model.eval()
    x_pt = torch.tensor(x_ref, device=DEVICE, dtype=torch.float32)
    t_pt = torch.tensor(t_ref, device=DEVICE, dtype=torch.float32)
    nx = x_pt.shape[0]
    nt = t_pt.shape[0]
    X = x_pt.view(1, nx).repeat(nt, 1)
    T = t_pt.view(nt, 1).repeat(1, nx)
    xt = torch.stack([X, T], dim=2).reshape(nt * nx, 2)

    u_pred_chunks = []
    CHUNK = 50000
    with torch.enable_grad():
        for s in range(0, xt.shape[0], CHUNK):
            c = xt[s:s+CHUNK].detach().clone().requires_grad_(True)
            u_pred_chunks.append(model.forward_proj(c).detach())
    u_pred = torch.cat(u_pred_chunks).reshape(nt, nx, out_dim).cpu().numpy()

    errs_l2, errs_linf = [], []
    for i in range(nt):
        u_true = u_ref[i]
        if out_dim == 1:
            e = u_pred[i, :, 0] - u_true[:, 0]
            errs_l2.append(float(np.sqrt(np.mean(e**2))))
            errs_linf.append(float(np.max(np.abs(e))))
        else:
            er = u_pred[i, :, 0] - u_true[:, 0]
            ei = u_pred[i, :, 1] - u_true[:, 1]
            en = np.sqrt(er**2 + ei**2)
            errs_l2.append(float(np.sqrt(np.mean(en**2))))
            errs_linf.append(float(np.max(en)))

    return {"t": t_ref.tolist(), "l2": errs_l2, "linf": errs_linf,
            "mean_l2": float(np.mean(errs_l2)), "max_linf": float(np.max(errs_linf))}


def eval_burgers_identity(model, inv0, n_quad=N_INV_QUAD):
    model.eval()
    norm = abs(inv0) + 1e-12
    resid_list, diss_list = [], []
    with torch.enable_grad():
        for t in T_EVAL_LIST:
            x = quad_grid(n_quad, requires_grad=False)
            t_leaf = torch.tensor(float(t), device=DEVICE, requires_grad=True)
            xt = torch.cat([x, t_leaf.expand_as(x)], dim=1).requires_grad_(True)
            u = model.forward_raw(xt) if isinstance(model, TwoStageProjPINN) else model(xt)
            E = PDE.burgers_E(u, xt)
            D = PDE.burgers_D(u, xt)
            dEdt = autograd.grad(E, t_leaf, create_graph=False)[0]
            r = dEdt + D
            resid_list.append(float((r / norm).abs().item()))
            diss_list.append(float((D / norm).abs().item()))
    return {
        "mean_abs_dEdt_plus_D": float(np.mean(resid_list)),
        "max_abs_dEdt_plus_D": float(np.max(resid_list)),
        "mean_abs_D": float(np.mean(diss_list)),
        "max_abs_D": float(np.max(diss_list)),
    }


def eval_constraint_error_raw(model, pde_type, inv_fn, inv0):
    if pde_type == "dissipative":
        return eval_burgers_identity(model, inv0, n_quad=N_INV_QUAD)

    model.eval()
    norm = abs(inv0) + 1e-12
    errs = []
    with torch.enable_grad():
        for t in T_EVAL_LIST:
            x = quad_grid(N_INV_QUAD, requires_grad=False)
            xt = torch.cat([x, float(t) * torch.ones_like(x)], dim=1).requires_grad_(True)
            u = model.forward_raw(xt) if isinstance(model, TwoStageProjPINN) else model(xt)
            I = inv_fn(u, xt)
            c = torch.abs((I - inv0) / norm)
            errs.append(c.detach())

    errs = torch.stack(errs)
    return {"mean": float(errs.mean().item()),
            "max": float(errs.max().item())}


def eval_constraint_error_proj(model, pde_type, inv_fn, inv0):
    if pde_type == "dissipative":
        return eval_burgers_identity(model, inv0, n_quad=N_INV_QUAD)

    model.eval()
    norm = abs(inv0) + 1e-12
    errs = []
    with torch.enable_grad():
        for t in T_EVAL_LIST:
            x = quad_grid(PROJ_NX, requires_grad=False)
            xt = torch.cat([x, float(t) * torch.ones_like(x)], dim=1).requires_grad_(True)
            u = model.forward_proj(xt) if isinstance(model, TwoStageProjPINN) else model(xt)
            I = inv_fn(u, xt)
            c = torch.abs((I - inv0) / norm)
            errs.append(c.detach())

    errs = torch.stack(errs)
    return {"mean": float(errs.mean().item()),
            "max": float(errs.max().item())}


def conservation_curve_proj(model, pde_type, inv_fn, inv0):
    model.eval()
    norm = abs(inv0) + 1e-12
    t_arr = np.linspace(0.0, T_FINAL, N_CONSERVATION_PTS)

    if pde_type == "dissipative":
        vals_resid, vals_D = [], []
        for t in t_arr:
            with torch.enable_grad():
                x = quad_grid(N_INV_QUAD, requires_grad=False)
                t_leaf = torch.tensor(float(t), device=DEVICE, requires_grad=True)
                xt = torch.cat([x, t_leaf.expand_as(x)], dim=1).requires_grad_(True)
                u = model.forward_raw(xt) if isinstance(model, TwoStageProjPINN) else model(xt)
                E = PDE.burgers_E(u, xt)
                D = PDE.burgers_D(u, xt)
                dEdt = autograd.grad(E, t_leaf, create_graph=False)[0]
                vals_resid.append(float(((dEdt + D) / norm).item()))
                vals_D.append(float((D / norm).item()))
        return {
            "t": t_arr.tolist(),
            "c_energy_identity": vals_resid,
            "c_dissipation": vals_D,
            "mean_abs_identity": float(np.mean(np.abs(vals_resid))),
            "max_abs_identity": float(np.max(np.abs(vals_resid))),
            "mean_abs_D": float(np.mean(np.abs(vals_D))),
            "max_abs_D": float(np.max(np.abs(vals_D))),
            "drift_rate_identity": float(np.polyfit(t_arr, vals_resid, 1)[0]),
            "drift_rate_D": float(np.polyfit(t_arr, vals_D, 1)[0]),
        }

    vals = []
    for t in t_arr:
        with torch.enable_grad():
            x = quad_grid(PROJ_NX, requires_grad=False)
            xt = torch.cat([x, float(t) * torch.ones_like(x)], dim=1).requires_grad_(True)
            u = model.forward_proj(xt) if isinstance(model, TwoStageProjPINN) else model(xt)
            I = inv_fn(u, xt)
            vals.append(((I - inv0) / norm).detach())

    vals_np = torch.stack(vals).cpu().numpy()
    return {"t": t_arr.tolist(), "c": vals_np.tolist(),
            "mean_abs": float(np.mean(np.abs(vals_np))),
            "max_abs": float(np.max(np.abs(vals_np))),
            "drift_rate": float(np.polyfit(t_arr, vals_np, 1)[0])}


# ==============================================================================
# REFERENCE SOLVER (ETDRK4)
# ==============================================================================
def spectral_grid(nx=NX_REF):
    x = np.linspace(X_MIN, X_MAX, nx, endpoint=False)
    L = X_MAX - X_MIN
    k = (2.0 * np.pi / L) * np.fft.fftfreq(nx, d=L / nx)
    return x, k


def etdrk4_coeffs(Lk, dt):
    E = np.exp(dt * Lk)
    E2 = np.exp(dt * Lk / 2.0)
    M = 16
    r = np.exp(1j * np.pi * (np.arange(1, M + 1) - 0.5) / M)
    LR = dt * Lk[:, None] + r[None, :]
    Q = dt * np.real(np.mean((np.exp(LR / 2.0) - 1.0) / LR, axis=1))
    f1 = dt * np.real(np.mean((-4 - LR + np.exp(LR)*(4 - 3*LR + LR**2)) / LR**3, axis=1))
    f2 = dt * np.real(np.mean((2 + LR + np.exp(LR)*(-2 + LR)) / LR**3, axis=1))
    f3 = dt * np.real(np.mean((-4 - 3*LR - LR**2 + np.exp(LR)*(4 - LR)) / LR**3, axis=1))
    return E, E2, Q, f1, f2, f3


def solve_reference(pde_name: str, out_dim: int):
    x, k = spectral_grid(NX_REF)
    dt = DT_REF_KS if pde_name == "KS" else DT_REF_DEFAULT
    nsteps = int(round(T_FINAL / dt))
    save_idx = np.arange(0, nsteps + 1, SAVE_EVERY)
    t_save = save_idx * dt
    if t_save[-1] < T_FINAL - 1e-12:
        save_idx = np.append(save_idx, nsteps)
        t_save = np.append(t_save, nsteps * dt)

    x_torch = torch.tensor(x, dtype=torch.float64)
    if pde_name == "KdV":
        u0 = (0.5 / torch.cosh(x_torch / 2.0) ** 2).numpy()
        u = u0.astype(np.complex128); out_dim = 1
    elif pde_name == "Burgers":
        u0 = (-torch.sin(np.pi * x_torch / 10.0)).numpy()
        u = u0.astype(np.complex128); out_dim = 1
    elif pde_name == "NLS":
        u0 = torch.exp(-x_torch**2 / 2.0).numpy()
        u = u0.astype(np.complex128); out_dim = 2
    elif pde_name == "KS":
        u0 = torch.cos(np.pi * x_torch / 16.0).numpy()
        u = u0.astype(np.complex128); out_dim = 1
    else:
        raise ValueError(pde_name)

    ik = 1j * k
    k2 = k**2

    if pde_name == "KdV":
        Lk = 1j * k**3
        def N(u_phys):
            ux = np.fft.ifft(ik * np.fft.fft(u_phys)).real
            return -6.0 * u_phys * ux
    elif pde_name == "Burgers":
        nu = PDE.NU
        Lk = -nu * k**2
        def N(u_phys):
            ux = np.fft.ifft(ik * np.fft.fft(u_phys)).real
            return -(u_phys * ux)
    elif pde_name == "NLS":
        Lk = 1j * (-0.5 * k2)
        def N(u_phys):
            return -1j * np.abs(u_phys)**2 * u_phys
    elif pde_name == "KS":
        Lk = k2 - k**4
        def N(u_phys):
            ux = np.fft.ifft(ik * np.fft.fft(u_phys)).real
            return -(u_phys * ux)
    else:
        raise ValueError(pde_name)

    E, E2, Q, f1, f2, f3 = etdrk4_coeffs(Lk.astype(np.complex128), dt)
    u_save = np.zeros((len(t_save), NX_REF, out_dim), dtype=np.float64)
    save_ptr = 0

    def save_state(uc):
        nonlocal save_ptr
        if pde_name == "NLS":
            u_save[save_ptr, :, 0] = uc.real
            u_save[save_ptr, :, 1] = uc.imag
        else:
            u_save[save_ptr, :, 0] = uc.real
        save_ptr += 1

    save_state(u)
    v = np.fft.fft(u)
    for n in range(1, nsteps + 1):
        up = np.fft.ifft(v).real if pde_name != "NLS" else np.fft.ifft(v)
        Nv = np.fft.fft(N(up))
        a = E2*v + Q*Nv
        ua = np.fft.ifft(a).real if pde_name != "NLS" else np.fft.ifft(a)
        Na = np.fft.fft(N(ua))
        b = E2*v + Q*Na
        ub = np.fft.ifft(b).real if pde_name != "NLS" else np.fft.ifft(b)
        Nb = np.fft.fft(N(ub))
        c = E2*a + Q*(2*Nb-Nv)
        uc = np.fft.ifft(c).real if pde_name != "NLS" else np.fft.ifft(c)
        Nc = np.fft.fft(N(uc))
        v = E*v + Nv*f1 + (Na+Nb)*f2 + Nc*f3
        if n in save_idx:
            save_state(np.fft.ifft(v))

    return x, t_save, u_save


# ==============================================================================
# MAIN
# ==============================================================================
METHODS_REGISTRY = [
    VanillaPINN, PenaltyPINN, FixedLambdaPINN, SAPINN_Pos, TwoStageProjPINN,
]


def main():
    log.info("Starting JCP FINAL v4.0.7 (Reviewer Patch)")
    log.info(f"Device: {DEVICE}")
    log.info(f"Methods: {[m.label for m in METHODS_REGISTRY]}")

    global_summary, ablation_table = {}, {}
    conservation_data, lambda_history = {}, {}

    for (pde_name, out_dim, pde_type) in PDE_LIST:
        log.info("=" * 60)
        log.info(f"PDE = {pde_name}")

        residual_fn, ic_fn, inv_fn = PDE_REGISTRY[pde_name]

        ref_path = os.path.join(RESULT_DIR, f"ref_{pde_name}.npz")
        if os.path.exists(ref_path):
            log.info("Load reference")
            data = np.load(ref_path)
            x_ref, t_ref, u_ref = data["x"], data["t"], data["u"]
        else:
            log.info("Solve reference (ETDRK4)")
            x_ref, t_ref, u_ref = solve_reference(pde_name, out_dim)
            np.savez_compressed(ref_path, x=x_ref, t=t_ref, u=u_ref)

        x0 = quad_grid(N_INV_QUAD, requires_grad=False)

        if pde_name == "KdV":
            inv0 = PDE.kdv_I_ic(x0)
        elif pde_name == "NLS":
            inv0 = PDE.nls_I_ic(x0)
        elif pde_name == "KS":
            inv0 = PDE.ks_I_ic(x0)
        else:
            xt0 = torch.cat([x0, torch.zeros_like(x0)], dim=1)
            u0 = PDE.burgers_ic(x0)
            inv0 = float(PDE.burgers_E(u0, xt0).item())

        log.info(f"I0 = {inv0:.4e}")

        pde_results = {}
        pde_ablation = {}
        pde_conservation = {}
        pde_lambda = {}

        tau = PDE_CAUSAL_TAU[pde_name]

        for MethodCls in METHODS_REGISTRY:
            log.info(f"Method: {MethodCls.label}")

            if MethodCls is FixedLambdaPINN:
                model = MethodCls(out_dim, pde_type, pde_name).to(DEVICE)
            elif MethodCls is TwoStageProjPINN:
                model = MethodCls(out_dim, pde_type, pde_name).to(DEVICE)
            else:
                model = MethodCls(out_dim, pde_type).to(DEVICE)

            rec = train_model(
                model, residual_fn, ic_fn, inv_fn, inv0, tau,
                pde_name, f"{pde_name}|{MethodCls.label}"
            )

            proj_stats = None
            resid_oos_proj = None
            if isinstance(model, TwoStageProjPINN) and pde_type == "conservative":
                log.info("Enabling projection (evaluation only)...")
                model.enable_projection(inv_fn, inv0)
                # 新增：计算投影参数统计
                proj_stats = get_projection_stats(model, time_slices(N_CONSERVATION_PTS))
                # 新增：计算投影后PDE残差
                resid_oos_proj = eval_residual_oos_proj(model, residual_fn)

            resid_oos = eval_residual_oos_raw(model, residual_fn)
            c_err_raw = eval_constraint_error_raw(model, pde_type, inv_fn, inv0)
            c_err_proj = eval_constraint_error_proj(model, pde_type, inv_fn, inv0)
            conv = conservation_curve_proj(model, pde_type, inv_fn, inv0)
            ref_err = eval_vs_reference_raw(model, x_ref, t_ref, u_ref, out_dim)

            ref_err_proj = None
            if isinstance(model, TwoStageProjPINN):
                ref_err_proj = eval_vs_reference_proj(model, x_ref, t_ref, u_ref, out_dim)

            if pde_type == "dissipative":
                mean_c_raw = c_err_raw["mean_abs_dEdt_plus_D"]
                mean_c_proj = c_err_proj["mean_abs_dEdt_plus_D"]
                drift = conv["drift_rate_identity"]
            else:
                mean_c_raw = c_err_raw["mean"]
                mean_c_proj = c_err_proj["mean"]
                drift = conv["drift_rate"]

            res_dict = {
                "label": MethodCls.label,
                "losses": {
                    "Lp": rec.Lp, "Lic": rec.Lic,
                    "Cinv": rec.Cinv, "Linv": rec.Linv,
                    "Ltot": rec.Ltot
                },
                "lambda": {"lam_ic": rec.lam_ic, "lam_inv": rec.lam_inv},
                "metrics": {
                    "residual_oos": resid_oos,
                    "residual_oos_proj": resid_oos_proj,  # 新增
                    "projection_stats": proj_stats,        # 新增
                    "constraint_raw": c_err_raw,
                    "constraint_proj": c_err_proj,
                    "conservation": conv,
                    "reference_error": ref_err,
                    "reference_error_proj": ref_err_proj,
                },
            }

            pde_results[MethodCls.label] = res_dict
            pde_conservation[MethodCls.label] = conv
            pde_lambda[MethodCls.label] = {"lam_ic": rec.lam_ic, "lam_inv": rec.lam_inv}

            # 消融表新增审稿人要求的字段
            ablation_entry = {
                "mean_l2_ref": ref_err["mean_l2"],
                "max_linf_ref": ref_err["max_linf"],
                "mean_resid_oos": resid_oos["mean"],
                "mean_constraint_violation_raw": mean_c_raw,
                "mean_constraint_violation_proj": mean_c_proj,
                "drift_rate": drift,
            }
            
            # 新增投影相关指标（仅TwoStage方法有）
            if resid_oos_proj:
                ablation_entry["mean_resid_oos_proj"] = resid_oos_proj["mean"]
                ablation_entry["resid_ratio_proj_over_raw"] = resid_oos_proj["mean"] / resid_oos["mean"]
            if proj_stats:
                ablation_entry.update(proj_stats)

            pde_ablation[MethodCls.label] = ablation_entry

            # 原有预测场保存逻辑完全不动
            x_t = torch.tensor(x_ref, device=DEVICE, dtype=torch.float32).unsqueeze(1)
            t_t = torch.tensor(t_ref, device=DEVICE, dtype=torch.float32).unsqueeze(1)

            nt = t_t.shape[0]
            nx = x_t.shape[0]

            x_all = x_t.repeat(nt, 1)
            t_all = t_t.repeat_interleave(nx, dim=0)
            xt_all = torch.cat([x_all, t_all], dim=1)

            pred_path = os.path.join(RESULT_DIR, f"pred_{pde_name}_{MethodCls.label}.npz")

            if isinstance(model, TwoStageProjPINN):
                with torch.no_grad():
                    u_raw_all = model.forward_raw(xt_all).reshape(nt, nx, out_dim).cpu().numpy()

                with torch.enable_grad():
                    chunk_size = 40000
                    u_proj_list = []
                    for start in range(0, xt_all.shape[0], chunk_size):
                        end = start + chunk_size
                        sub_xt = xt_all[start:end].detach().clone().requires_grad_(True)
                        sub_u = model.forward_proj(sub_xt).detach()
                        u_proj_list.append(sub_u)
                    u_proj_all = torch.cat(u_proj_list, dim=0).reshape(nt, nx, out_dim).cpu().numpy()

                np.savez_compressed(
                    pred_path,
                    x=x_ref,
                    t=t_ref,
                    u_raw=u_raw_all,
                    u_proj=u_proj_all
                )
            else:
                with torch.no_grad():
                    u_pred_all = model(xt_all).reshape(nt, nx, out_dim).cpu().numpy()
                np.savez_compressed(
                    pred_path,
                    x=x_ref,
                    t=t_ref,
                    u=u_pred_all
                )
            log.info(f"Saved field data -> {pred_path}")

            # 新增：打印审稿人关心的关键指标
            if pde_type == "dissipative":
                log.info(
                    f"[{MethodCls.label:18s}] |dE/dt+D|={conv['mean_abs_identity']:.3e} "
                    f"L2={ref_err['mean_l2']:.3e}"
                )
            else:
                if isinstance(model, TwoStageProjPINN):
                    log.info(
                        f"[{MethodCls.label:18s}] |c_raw|={mean_c_raw:.3e} |c_proj|={mean_c_proj:.3e} "
                        f"L2_raw={ref_err['mean_l2']:.3e} L2_proj={ref_err_proj['mean_l2']:.3e}"
                    )
                    # 新增：打印残差比和投影幅度
                    if resid_oos_proj:
                        log.info(f"                     Resid ratio: {resid_oos_proj['mean']/resid_oos['mean']:.3f}x")
                    if proj_stats:
                        if out_dim == 1:
                            log.info(f"                     Max |α|: {proj_stats['max_abs_alpha']:.3e}")
                        else:
                            log.info(f"                     Max |s-1|: {proj_stats['max_abs_s_minus_1']:.3e}")
                else:
                    log.info(
                        f"[{MethodCls.label:18s}] |c_raw|={mean_c_raw:.3e} "
                        f"|c_proj|={mean_c_proj:.3e} L2={ref_err['mean_l2']:.3e}"
                    )

        global_summary[pde_name] = pde_results
        ablation_table[pde_name] = pde_ablation
        conservation_data[pde_name] = pde_conservation
        lambda_history[pde_name] = pde_lambda

    with open(os.path.join(RESULT_DIR, "summary_results.json"), "w", encoding="utf-8") as f:
        json.dump(global_summary, f, indent=2, ensure_ascii=False)

    with open(os.path.join(RESULT_DIR, "ablation_table.json"), "w", encoding="utf-8") as f:
        json.dump(ablation_table, f, indent=2, ensure_ascii=False)

    log.info("\n=============================================")
    log.info("All experiments finished successfully!")
    log.info(f"All results saved in: {RESULT_DIR}")
    log.info("✅ Indentation error FIXED 100%")
    log.info("✅ TwoStage-Proj: raw vs proj L2/L∞ fully compared")
    log.info("✅ ✅ NEW: Residual preservation test (reviewer required)")
    log.info("✅ ✅ NEW: Projection amplitude statistics (reviewer required)")
    log.info("✅ JSON + NPZ + LOG all have complete comparison")


if __name__ == "__main__":
    main()
