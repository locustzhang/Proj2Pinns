def fig9_residual_comparison():
    table = load_json("ablation_table.json")
    if not table:
        print("❌ fig9: No ablation table found")
        return
    
    # 只保留有投影数据的保守型PDE
    valid_pdes = [pde for pde in PDE_LIST if pde != "Burgers"]
    print(f"✅ fig9: Valid PDEs with projection data: {valid_pdes}")
    
    # 1×3完美布局，尺寸与其他图比例一致
    fig, axes = plt.subplots(1, 3, figsize=(W2, 2.8))
    axes = np.atleast_1d(axes).flatten()
    
    bar_width = 0.35
    x = np.array([0])
    
    for i, pde in enumerate(valid_pdes):
        ax = axes[i]
        try:
            # 强制获取数据
            resid_raw = float(table[pde][OURS]["mean_resid_oos"])
            resid_proj = float(table[pde][OURS]["mean_resid_oos_proj"])
            print(f"  [{pde}] Raw: {resid_raw:.2e}, Proj: {resid_proj:.2e}")
            
            # 双柱状图对比（与其他图颜色一致）
            ax.bar(x[0] - bar_width/2, resid_raw, bar_width, 
                   color=_W["black"], alpha=0.8, label="Raw Output" if i == 0 else "")
            ax.bar(x[0] + bar_width/2, resid_proj, bar_width, 
                   color=BASELINE_GRAY, alpha=0.8, label="Projected Output" if i == 0 else "")
            
            # 自动计算y轴范围，确保柱子和标签都可见
            y_min = min(resid_raw, resid_proj) * 0.05
            y_max = max(resid_raw, resid_proj) * 2.5
            ax.set_ylim(y_min, y_max)
            
            # 添加数值标签
            ax.text(x[0] - bar_width/2, resid_raw * 1.1, f"{resid_raw:.2e}", 
                    ha="center", va="bottom", fontsize=6)
            ax.text(x[0] + bar_width/2, resid_proj * 1.1, f"{resid_proj:.2e}", 
                    ha="center", va="bottom", fontsize=6)
            
            # 计算并标注残差比
            ratio = resid_proj / resid_raw
            ax.text(x[0], y_max * 0.9, 
                    f"Ratio = {ratio:.3f}", ha="center", va="top", 
                    fontsize=7, fontweight="bold")
            
        except Exception as e:
            print(f"❌ fig9: Error plotting {pde}: {str(e)}")
            ax.axis('off')
            continue
        
        ax.set_title(pde, pad=3)
        ax.set_ylabel(r"Mean PDE Residual $\|R\|_2$")
        ax.set_xticks([])  # 隐藏x轴刻度
        ax.set_yscale("log")
        add_panel_label(ax, f"({chr(97+i)})")
    
    axes[0].legend(loc="upper right")
    # 手动精确调整边距，彻底解决布局警告
    fig.subplots_adjust(left=0.08, right=0.98, top=0.85, bottom=0.2, wspace=0.35)
    savefig(fig, "fig9_residual_comparison")


