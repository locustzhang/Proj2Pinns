def smooth(arr, w=60):
    return uniform_filter1d(np.asarray(arr, dtype=float), size=w, mode="nearest")

def load_json(fname):
    path = os.path.join(RESULT_DIR, fname)
    spath = os.path.join(RESULT_DIR, "summary_results.json")
    if os.path.exists(spath):
        with open(spath, "r", encoding="utf-8") as f:
            summary = json.load(f)
        if "conservation_all" in fname:
            conv = {}
            for pde in PDE_LIST:
                conv[pde] = {}
                for m in METHOD_KEYS:
                    try:
                        conv[pde][m] = summary[pde][m]["metrics"]["conservation"]
                    except:
                        conv[pde][m] = {"t": [], "c": [], "c_energy_identity": []}
            return conv
        if "lambda_all" in fname:
            lam = {}
            for pde in PDE_LIST:
                lam[pde] = {}
                for m in METHOD_KEYS:
                    try:
                        lam[pde][m] = summary[pde][m]["lambda"]
                    except:
                        lam[pde][m] = {"lam_inv": [0], "lam_ic": [0]}
            return lam
    if not os.path.exists(path):
        return {}
    with open(path, "r", encoding="utf-8") as f:
        return json.load(f)

def robust_log_ylim(y_all, pad_decades=0.8, floor=1e-16):
    y_all = np.asarray(y_all)
    ymin = max(np.min(y_all[(y_all > 0) & np.isfinite(y_all)]), floor)
    ymax = np.max(y_all[(y_all > 0) & np.isfinite(y_all)])
    log_ymin = np.floor(np.log10(ymin)) - pad_decades
    log_ymax = np.ceil(np.log10(ymax)) + 0.25
    return 10**log_ymin, 10**log_ymax

def pareto_frontier(x, y):
    x, y = np.asarray(x), np.asarray(y)
    mask = np.isfinite(x) & np.isfinite(y)
    x, y = x[mask], y[mask]
    order = np.argsort(x)
    x, y = x[order], y[order]
    fx, fy, best_y = [], [], np.inf
    for xi, yi in zip(x, y):
        if yi <= best_y:
            fx.append(xi)
            fy.append(yi)
            best_y = yi
    return np.array(fx), np.array(fy)

def choose_best_baseline(table, pde, key="mean_constraint_violation_proj"):
    return min([m for m in METHOD_KEYS if m != OURS], key=lambda m: table[pde][m][key])

def format_sci(x, dec=2):
    if x == 0: return "0.00"
    exp = int(np.floor(np.log10(abs(x))))
    return f"{x/10**exp:.{dec}f}×$10^{{{exp}}}$"

